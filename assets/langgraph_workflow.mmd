---
config:
  flowchart:
    curve: linear
---
graph TD;
	__start__([<p>__start__</p>]):::first
	classifier(classifier)
	sql(sql)
	rag(rag)
	hybrid(hybrid)
	summarize(summarize)
	error(error)
	__end__([<p>__end__</p>]):::last
	__start__ --> classifier;
	classifier -.-> error;
	classifier -.-> hybrid;
	classifier -.-> rag;
	classifier -.-> sql;
	hybrid -.-> error;
	hybrid -.-> summarize;
	rag -.-> error;
	rag -.-> summarize;
	sql -.-> error;
	sql -.-> summarize;
	error --> __end__;
	summarize --> __end__;
	classDef default fill:#f2f0ff,line-height:1.2
	classDef first fill-opacity:0
	classDef last fill:#bfb6fc
